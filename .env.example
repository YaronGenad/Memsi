# Priority ERP credentials
# Copy this file to .env and fill in your actual values
PRIORITY_AUTH_HEADER=Basic <base64-encoded-user:password>
PRIORITY_BASE_URL=https://<your-priority-server>/odata/Priority/tabula.ini/<company>

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=priority_cache
DB_USER=postgres
DB_PASSWORD=<your-db-password>
